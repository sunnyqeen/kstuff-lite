diff --git a/library/sha1.c b/library/sha1.c
index dfbe481..1af4c56 100644
--- a/library/sha1.c
+++ b/library/sha1.c
@@ -232,6 +232,51 @@ int mbedtls_internal_sha1_process(mbedtls_sha1_context *ctx,
 
 #endif /* !MBEDTLS_SHA1_PROCESS_ALT */
 
+
+/*
+ * x86/x64 SHA-NI support wrapper  
+ */
+#if !defined(MBEDTLS_SHA1_PROCESS_ALT) && defined(MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT)
+
+#include "sha1_x86.h"
+
+#if defined(MBEDTLS_SHA1_X86_HAVE_CODE)
+
+/* Declare C implementation as external (defined above) */
+extern int mbedtls_internal_sha1_process(mbedtls_sha1_context *ctx,
+                                         const unsigned char data[64]);
+
+static int mbedtls_sha1_x86_support_cached(void)
+{
+    static int done = 0;
+    static int supported = 0;
+
+    if (!done) {
+        supported = mbedtls_sha1_x86_has_support(MBEDTLS_SHA1_X86_SHA_NI);
+        done = 1;
+    }
+
+    return supported;
+}
+
+/* Wrapper function that dispatches to x86 or C */
+static int mbedtls_internal_sha1_process_dispatch(mbedtls_sha1_context *ctx,
+                                                   const unsigned char data[64])
+{
+    if (mbedtls_sha1_x86_support_cached()) {
+        mbedtls_sha1_x86_process(ctx, data, 1);
+        return 0;
+    }
+    return mbedtls_internal_sha1_process(ctx, data);
+}
+
+/* Replace all calls to mbedtls_internal_sha1_process with dispatch */
+#define mbedtls_internal_sha1_process mbedtls_internal_sha1_process_dispatch
+
+#endif /* MBEDTLS_SHA1_X86_HAVE_CODE */
+
+#endif /* !MBEDTLS_SHA1_PROCESS_ALT && MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT */
+
 /*
  * SHA-1 process buffer
  */
diff --git a/library/sha1_x86.c b/library/sha1_x86.c
new file mode 100644
index 0000000..7b19d5e
--- /dev/null
+++ b/library/sha1_x86.c
@@ -0,0 +1,268 @@
+/**
+ * \file sha1_x86.c
+ *
+ * \brief SHA-NI (SHA Native Instructions) for hardware SHA-1 acceleration on x86/x64 processors
+ */
+/*
+ *  Copyright The Mbed TLS Contributors
+ *  SPDX-License-Identifier: Apache-2.0 OR GPL-2.0-or-later
+ */
+
+#include "common.h"
+
+#if defined(MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT) && \
+    (defined(MBEDTLS_ARCH_IS_X64) || defined(MBEDTLS_ARCH_IS_X86))
+
+#include "mbedtls/sha1.h"
+#include "sha1_x86.h"
+
+#include <string.h>
+
+#if defined(MBEDTLS_SHA1_X86_HAVE_CODE)
+
+#if defined(MBEDTLS_SHA1_X86_HAVE_INTRINSICS)
+
+#if defined(_MSC_VER)
+#include <immintrin.h>
+#include <intrin.h>
+#elif defined(__GNUC__) || defined(__clang__)
+#include <cpuid.h>
+#include <immintrin.h>
+#endif
+
+/*
+ * SHA-1 block processing using SHA-NI intrinsics
+ * Based on Intel's SHA Extensions white paper
+ */
+
+/* Byte-swap 32-bit values in a 128-bit vector */
+#define SHUF_MASK _mm_set_epi64x(0x0001020304050607ULL, 0x08090a0b0c0d0e0fULL)
+
+void mbedtls_sha1_x86_process(mbedtls_sha1_context *ctx,
+                              const unsigned char *data,
+                              size_t blocks)
+{
+    __m128i ABCD, ABCD_SAVE, E0, E0_SAVE, E1;
+    __m128i MSG0, MSG1, MSG2, MSG3;
+    const __m128i MASK = SHUF_MASK;
+
+    /* Load initial state */
+    ABCD = _mm_loadu_si128((__m128i *) &ctx->state[0]);
+    E0 = _mm_set_epi32(ctx->state[4], 0, 0, 0);
+
+    /* Reverse for SHA-1 processing order */
+    ABCD = _mm_shuffle_epi32(ABCD, 0x1B);
+
+    while (blocks > 0) {
+        /* Save current state */
+        ABCD_SAVE = ABCD;
+        E0_SAVE = E0;
+
+        /* Load message blocks and convert endianness */
+        MSG0 = _mm_loadu_si128((__m128i *)(data + 0));
+        MSG0 = _mm_shuffle_epi8(MSG0, MASK);
+        MSG1 = _mm_loadu_si128((__m128i *)(data + 16));
+        MSG1 = _mm_shuffle_epi8(MSG1, MASK);
+        MSG2 = _mm_loadu_si128((__m128i *)(data + 32));
+        MSG2 = _mm_shuffle_epi8(MSG2, MASK);
+        MSG3 = _mm_loadu_si128((__m128i *)(data + 48));
+        MSG3 = _mm_shuffle_epi8(MSG3, MASK);
+
+        /* Rounds 0-3 */
+        E0 = _mm_add_epi32(E0, MSG0);
+        E1 = ABCD;
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 0);
+
+        /* Rounds 4-7 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG1);
+        E0 = ABCD;
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 0);
+        MSG0 = _mm_sha1msg1_epu32(MSG0, MSG1);
+
+        /* Rounds 8-11 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG2);
+        E1 = ABCD;
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 0);
+        MSG1 = _mm_sha1msg1_epu32(MSG1, MSG2);
+        MSG0 = _mm_xor_si128(MSG0, MSG2);
+
+        /* Rounds 12-15 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG3);
+        E0 = ABCD;
+        MSG0 = _mm_sha1msg2_epu32(MSG0, MSG3);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 0);
+        MSG2 = _mm_sha1msg1_epu32(MSG2, MSG3);
+        MSG1 = _mm_xor_si128(MSG1, MSG3);
+
+        /* Rounds 16-19 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG0);
+        E1 = ABCD;
+        MSG1 = _mm_sha1msg2_epu32(MSG1, MSG0);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 0);
+        MSG3 = _mm_sha1msg1_epu32(MSG3, MSG0);
+        MSG2 = _mm_xor_si128(MSG2, MSG0);
+
+        /* Rounds 20-23 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG1);
+        E0 = ABCD;
+        MSG2 = _mm_sha1msg2_epu32(MSG2, MSG1);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 1);
+        MSG0 = _mm_sha1msg1_epu32(MSG0, MSG1);
+        MSG3 = _mm_xor_si128(MSG3, MSG1);
+
+        /* Rounds 24-27 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG2);
+        E1 = ABCD;
+        MSG3 = _mm_sha1msg2_epu32(MSG3, MSG2);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 1);
+        MSG1 = _mm_sha1msg1_epu32(MSG1, MSG2);
+        MSG0 = _mm_xor_si128(MSG0, MSG2);
+
+        /* Rounds 28-31 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG3);
+        E0 = ABCD;
+        MSG0 = _mm_sha1msg2_epu32(MSG0, MSG3);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 1);
+        MSG2 = _mm_sha1msg1_epu32(MSG2, MSG3);
+        MSG1 = _mm_xor_si128(MSG1, MSG3);
+
+        /* Rounds 32-35 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG0);
+        E1 = ABCD;
+        MSG1 = _mm_sha1msg2_epu32(MSG1, MSG0);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 1);
+        MSG3 = _mm_sha1msg1_epu32(MSG3, MSG0);
+        MSG2 = _mm_xor_si128(MSG2, MSG0);
+
+        /* Rounds 36-39 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG1);
+        E0 = ABCD;
+        MSG2 = _mm_sha1msg2_epu32(MSG2, MSG1);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 1);
+        MSG0 = _mm_sha1msg1_epu32(MSG0, MSG1);
+        MSG3 = _mm_xor_si128(MSG3, MSG1);
+
+        /* Rounds 40-43 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG2);
+        E1 = ABCD;
+        MSG3 = _mm_sha1msg2_epu32(MSG3, MSG2);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 2);
+        MSG1 = _mm_sha1msg1_epu32(MSG1, MSG2);
+        MSG0 = _mm_xor_si128(MSG0, MSG2);
+
+        /* Rounds 44-47 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG3);
+        E0 = ABCD;
+        MSG0 = _mm_sha1msg2_epu32(MSG0, MSG3);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 2);
+        MSG2 = _mm_sha1msg1_epu32(MSG2, MSG3);
+        MSG1 = _mm_xor_si128(MSG1, MSG3);
+
+        /* Rounds 48-51 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG0);
+        E1 = ABCD;
+        MSG1 = _mm_sha1msg2_epu32(MSG1, MSG0);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 2);
+        MSG3 = _mm_sha1msg1_epu32(MSG3, MSG0);
+        MSG2 = _mm_xor_si128(MSG2, MSG0);
+
+        /* Rounds 52-55 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG1);
+        E0 = ABCD;
+        MSG2 = _mm_sha1msg2_epu32(MSG2, MSG1);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 2);
+        MSG0 = _mm_sha1msg1_epu32(MSG0, MSG1);
+        MSG3 = _mm_xor_si128(MSG3, MSG1);
+
+        /* Rounds 56-59 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG2);
+        E1 = ABCD;
+        MSG3 = _mm_sha1msg2_epu32(MSG3, MSG2);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 2);
+        MSG1 = _mm_sha1msg1_epu32(MSG1, MSG2);
+        MSG0 = _mm_xor_si128(MSG0, MSG2);
+
+        /* Rounds 60-63 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG3);
+        E0 = ABCD;
+        MSG0 = _mm_sha1msg2_epu32(MSG0, MSG3);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 3);
+        MSG2 = _mm_sha1msg1_epu32(MSG2, MSG3);
+        MSG1 = _mm_xor_si128(MSG1, MSG3);
+
+        /* Rounds 64-67 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG0);
+        E1 = ABCD;
+        MSG1 = _mm_sha1msg2_epu32(MSG1, MSG0);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 3);
+        MSG3 = _mm_sha1msg1_epu32(MSG3, MSG0);
+        MSG2 = _mm_xor_si128(MSG2, MSG0);
+
+        /* Rounds 68-71 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG1);
+        E0 = ABCD;
+        MSG2 = _mm_sha1msg2_epu32(MSG2, MSG1);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 3);
+        MSG3 = _mm_xor_si128(MSG3, MSG1);
+
+        /* Rounds 72-75 */
+        E0 = _mm_sha1nexte_epu32(E0, MSG2);
+        E1 = ABCD;
+        MSG3 = _mm_sha1msg2_epu32(MSG3, MSG2);
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E0, 3);
+
+        /* Rounds 76-79 */
+        E1 = _mm_sha1nexte_epu32(E1, MSG3);
+        E0 = ABCD;
+        ABCD = _mm_sha1rnds4_epu32(ABCD, E1, 3);
+
+        /* Combine with previous state */
+        E0 = _mm_sha1nexte_epu32(E0, E0_SAVE);
+        ABCD = _mm_add_epi32(ABCD, ABCD_SAVE);
+
+        data += 64;
+        blocks--;
+    }
+
+    /* Store state */
+    ABCD = _mm_shuffle_epi32(ABCD, 0x1B);
+    _mm_storeu_si128((__m128i *) &ctx->state[0], ABCD);
+    ctx->state[4] = _mm_extract_epi32(E0, 3);
+}
+
+/*
+ * CPUID detection for SHA-NI support
+ */
+int mbedtls_sha1_x86_has_support(unsigned int what)
+{
+    if (what != MBEDTLS_SHA1_X86_SHA_NI)
+        return 0;
+
+#if defined(_MSC_VER)
+    int info[4];
+    __cpuidex(info, 7, 0);
+    /* SHA extensions are bit 29 of EBX */
+    return (info[1] & (1 << 29)) != 0;
+#elif defined(__GNUC__) || defined(__clang__)
+    unsigned int CPUInfo[4];
+
+    /* Check if CPUID leaf 7 is supported */
+    __cpuid(0, CPUInfo[0], CPUInfo[1], CPUInfo[2], CPUInfo[3]);
+    if (CPUInfo[0] < 7)
+        return 0;
+
+    /* Get extended features */
+    __cpuid_count(7, 0, CPUInfo[0], CPUInfo[1], CPUInfo[2], CPUInfo[3]);
+
+    /* SHA extensions are bit 29 of EBX */
+    return (CPUInfo[1] & (1 << 29)) != 0;
+#else
+    return 0;
+#endif
+}
+
+#endif /* MBEDTLS_SHA1_X86_HAVE_INTRINSICS */
+
+#endif /* MBEDTLS_SHA1_X86_HAVE_CODE */
+
+#endif /* defined(MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT) && (X64 || X86) */
diff --git a/library/sha1_x86.h b/library/sha1_x86.h
new file mode 100644
index 0000000..26c29b7
--- /dev/null
+++ b/library/sha1_x86.h
@@ -0,0 +1,89 @@
+/**
+ * \file sha1_x86.h
+ *
+ * \brief SHA-NI (SHA Native Instructions) for hardware SHA-1 acceleration on x86/x64 processors
+ *
+ * \warning These functions are only for internal use by other library
+ *          functions; you must not call them directly.
+ */
+/*
+ *  Copyright The Mbed TLS Contributors
+ *  SPDX-License-Identifier: Apache-2.0 OR GPL-2.0-or-later
+ */
+#ifndef MBEDTLS_SHA1_X86_H
+#define MBEDTLS_SHA1_X86_H
+
+#include "mbedtls/build_info.h"
+
+#include "mbedtls/sha1.h"
+
+#define MBEDTLS_SHA1_X86_SHA_NI      0x20000000u
+
+#if defined(MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT) && \
+    (defined(MBEDTLS_ARCH_IS_X64) || defined(MBEDTLS_ARCH_IS_X86))
+
+/* Can we do SHA-NI with intrinsics?
+ * (Only implemented with certain compilers, only for certain targets.)
+ */
+#undef MBEDTLS_SHA1_X86_HAVE_INTRINSICS
+#if defined(_MSC_VER) && !defined(__clang__)
+/* Visual Studio supports SHA intrinsics since VS 2015. */
+#if _MSC_VER >= 1900
+#define MBEDTLS_SHA1_X86_HAVE_INTRINSICS
+#endif
+#endif
+/* GCC-like compilers: currently, we only support intrinsics if the requisite
+ * target flag is enabled when building the library (e.g. `gcc -msha -msse4.1`
+ * or `clang -msha -msse4.1`). */
+#if (defined(__GNUC__) || defined(__clang__)) && defined(__SHA__)
+#define MBEDTLS_SHA1_X86_HAVE_INTRINSICS
+#endif
+
+#if defined(MBEDTLS_SHA1_X86_HAVE_INTRINSICS)
+#define MBEDTLS_SHA1_X86_HAVE_CODE 1 // via intrinsics
+#endif
+
+#if defined(MBEDTLS_SHA1_X86_HAVE_CODE)
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * \brief          Internal function to detect the SHA-NI feature in CPUs.
+ *
+ * \note           This function is only for internal use by other library
+ *                 functions; you must not call it directly.
+ *
+ * \param what     The feature to detect
+ *                 (MBEDTLS_SHA1_X86_SHA_NI)
+ *
+ * \return         1 if CPU has support for the feature, 0 otherwise
+ */
+int mbedtls_sha1_x86_has_support(unsigned int what);
+
