diff --git a/library/CMakeLists.txt b/library/CMakeLists.txt
index 4834793..c7a4c9d 100644
--- a/library/CMakeLists.txt
+++ b/library/CMakeLists.txt
@@ -247,6 +247,27 @@ if(LINK_WITH_TRUSTED_STORAGE)
     set(libs ${libs} trusted_storage)
 endif()
 
+# Special compilation for SHA-NI hardware acceleration on x86/x64
+# Only include SHA-NI files when targeting x86/x64 architectures (cross-compilation safe)
+if(CMAKE_SYSTEM_PROCESSOR MATCHES "(x86)|(X86)|(amd64)|(AMD64)|(x86_64)|(i.86)")
+    message(STATUS "Enabling SHA-NI x86/x64 hardware acceleration support")
+
+    # Add SHA-NI source files to the crypto library
+    list(APPEND src_crypto sha1_x86.c sha256_x86.c)
+
+    # Set compiler-specific flags for SHA-NI intrinsics
+    if(CMAKE_COMPILER_IS_GNUCC OR CMAKE_C_COMPILER_ID MATCHES "Clang")
+        # GCC and Clang need explicit flags to enable SHA-NI and SSE4.1 intrinsics
+        set_source_files_properties(sha1_x86.c PROPERTIES COMPILE_FLAGS "-msha -msse4.1")
+        set_source_files_properties(sha256_x86.c PROPERTIES COMPILE_FLAGS "-msha -msse4.1")
+    elseif(CMAKE_C_COMPILER_ID MATCHES "MSVC")
+        # MSVC automatically enables intrinsics based on target architecture
+        # No special flags needed for SHA-NI intrinsics
+    endif()
+else()
+    message(STATUS "SHA-NI x86/x64 acceleration disabled (target architecture: ${CMAKE_SYSTEM_PROCESSOR})")
+endif()
+
 if (NOT USE_STATIC_MBEDTLS_LIBRARY AND NOT USE_SHARED_MBEDTLS_LIBRARY)
     message(FATAL_ERROR "Need to choose static or shared mbedtls build!")
 endif(NOT USE_STATIC_MBEDTLS_LIBRARY AND NOT USE_SHARED_MBEDTLS_LIBRARY)
