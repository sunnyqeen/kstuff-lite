+ * \note SHA-NI is supported on Intel processors from Goldmont and Skylake
+ * microarchitectures onwards, and AMD Ryzen processors.
+ *
+ * Requires: MBEDTLS_SHA1_C.
+ *
+ * Module:  library/sha1.c
+ * Module:  library/sha1_x86.c
+ *
+ * Uncomment to have the library check for the x86/x64 SHA-NI extensions
+ * and use them if available.
+ */
+#define MBEDTLS_SHA1_USE_X86_SHA_NI_IF_PRESENT
+
